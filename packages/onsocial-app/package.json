{
  "name": "@onsocial/app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build:deps": "pnpm --filter @onsocial/ui run build && pnpm --filter @onsocial/sdk... run build",
    "predev": "pnpm run build:deps",
    "dev": "next dev --port 3060",
    "prebuild": "pnpm run build:deps",
    "pretype-check": "pnpm run build:deps",
    "build": "next build",
    "start": "next start",
    "format": "prettier --write .",
    "lint": "eslint .",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "check": "pnpm lint && pnpm type-check && pnpm test && pnpm build"
  },
  "dependencies": {
    "@hot-labs/near-connect": "^0.11.4",
    "@onsocial/sdk": "workspace:*",
    "@onsocial/ui": "workspace:*",
    "lucide-react": "^0.577.0",
    "next": "^16.2.9",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-icons": "^5.6.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/node": "^25.4.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.9",
    "postcss": "^8.5.8",
    "prettier": "^3.6.2",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
