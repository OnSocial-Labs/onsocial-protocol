{
  "name": "@onsocial/ui",
  "version": "0.1.0",
  "description": "Shared OnSocial protocol UI primitives for Portal and OnPage.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./protocol.css": "./protocol.css",
    "./dividers.css": "./dividers.css",
    "./glass-sheet.css": "./glass-sheet.css",
    "./pulsing-dots.css": "./pulsing-dots.css"
  },
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "lint": "eslint src",
    "format": "prettier --write 'src/**/*.{ts,tsx}' '*.{json,js,css}'",
    "format:check": "prettier --check 'src/**/*.{ts,tsx}' '*.{json,js,css}'",
    "test": "vitest run",
    "check": "pnpm lint && pnpm format:check && pnpm build && pnpm test"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.5.0"
  },
  "peerDependencies": {
    "react": "^19.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.30.1",
    "@types/react": "^19.2.14",
    "eslint": "^9.39.4",
    "prettier": "^3.6.2",
    "react": "^19.2.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0",
    "vitest": "^3.2.4"
  },
  "files": [
    "dist",
    "src",
    "protocol.css",
    "dividers.css",
    "glass-sheet.css",
    "pulsing-dots.css"
  ],
  "license": "MIT",
  "author": "OnSocial Labs <dev@onsocial.id> (https://onsocial.id)",
  "repository": {
    "type": "git",
    "url": "https://github.com/OnSocial-Labs/onsocial-protocol.git",
    "directory": "packages/onsocial-ui"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "onsocial",
    "react",
    "ui",
    "protocol"
  ]
}
