{
  "name": "@onsocial/sdk",
  "version": "0.1.0",
  "description": "OnSocial Protocol SDK — social graph, scarces (NFTs), rewards, storage, and GraphQL queries",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./advanced": {
      "import": "./dist/advanced/index.js",
      "types": "./dist/advanced/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "lint": "eslint src",
    "format": "prettier --write 'src/**/*.{ts,js,json}' 'tests/**/*.ts' '*.{json,md,js}'",
    "format:check": "prettier --check 'src/**/*.{ts,js,json}' 'tests/**/*.ts' '*.{json,md,js}'",
    "test": "vitest run src",
    "test:integration": "vitest run tests/integration --fileParallelism=false",
    "test:all": "vitest run",
    "diag:cards": "tsx tests/integration/diag-mint-cards.mts",
    "diag:receipt": "tsx tests/integration/diag-receipt-yellow.mts",
    "check": "pnpm lint && pnpm format:check && pnpm build && pnpm test"
  },
  "dependencies": {
    "@onsocial/text-card": "workspace:*"
  },
  "devDependencies": {
    "@eslint/js": "^9.30.1",
    "eslint": "^9.39.4",
    "prettier": "^3.6.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0",
    "vitest": "^3.2.4"
  },
  "files": [
    "dist",
    "src"
  ],
  "license": "MIT",
  "author": "OnSocial Labs <dev@onsocial.id> (https://onsocial.id)",
  "repository": {
    "type": "git",
    "url": "https://github.com/OnSocial-Labs/onsocial-protocol.git",
    "directory": "packages/onsocial-sdk"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "onsocial",
    "near",
    "social",
    "web3",
    "sdk",
    "nft",
    "scarces",
    "rewards",
    "gasless"
  ]
}
