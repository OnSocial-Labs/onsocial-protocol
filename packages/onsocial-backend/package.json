{
  "name": "onsocial-backend",
  "version": "0.1.0",
  "description": "OnSocial Backend - Telegram rewards bot and reward crediting service",
  "author": "OnSocial Labs",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint src",
    "format": "prettier --write .",
    "test": "vitest run tests/unit",
    "test:watch": "vitest tests/unit",
    "test:all": "vitest run",
    "migrate": "node dist/db/migrate.js"
  },
  "dependencies": {
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "grammy": "^1.35.0",
    "near-api-js": "^7.1.0",
    "pg": "^8.16.0",
    "pino": "^10.3.0",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.30.1",
    "@types/express": "^5.0.3",
    "@types/node": "^24.0.10",
    "@types/pg": "^8.15.4",
    "@types/supertest": "^7.2.0",
    "eslint": "^9.30.1",
    "prettier": "^3.6.2",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.54.0",
    "vitest": "^3.2.4"
  }
