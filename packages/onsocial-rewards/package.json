{
  "name": "@onsocial-id/rewards",
  "version": "0.1.0",
  "description": "SDK for crediting and querying SOCIAL token rewards via the OnSocial relayer",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./bot": {
      "import": "./dist/bot.js",
      "types": "./dist/bot.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "lint": "eslint src",
    "format": "prettier --write .",
    "test": "vitest run"
  },
  "peerDependencies": {
    "grammy": "^1.0.0"
  },
  "peerDependenciesMeta": {
    "grammy": {
      "optional": true
    }
  },
  "devDependencies": {
    "@eslint/js": "^9.30.1",
    "eslint": "^9.30.1",
    "grammy": "^1.41.1",
    "prettier": "^3.6.2",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.54.0",
    "vitest": "^3.2.4"
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "license": "MIT",
  "author": "OnSocial Labs <dev@onsocial.id> (https://onsocial.id)",
  "repository": {
    "type": "git",
    "url": "https://github.com/OnSocial-Labs/onsocial-protocol.git",
    "directory": "packages/onsocial-rewards"
  },
  "homepage": "https://github.com/OnSocial-Labs/onsocial-protocol/tree/main/packages/onsocial-rewards#readme",
  "bugs": {
    "url": "https://github.com/OnSocial-Labs/onsocial-protocol/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "onsocial",
    "near",
    "rewards",
    "social-token",
    "telegram",
    "grammy",
    "web3"
  ]
