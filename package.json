{
  "name": "onsocial-protocol",
  "version": "0.1.0",
  "devDependencies": {
    "@eslint/js": "^9.30.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/morgan": "^1.9.10",
    "@types/node": "^25.4.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/parser": "^8.57.0",
    "@vitest/eslint-plugin": "^1.6.9",
    "eslint": "^9.39.4",
    "eslint-plugin-prettier": "^5.5.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.1.2",
    "prettier": "^3.6.2",
    "react-dom": "^19.2.4",
    "react-test-renderer": "^19.2.4",
    "syncpack": "^13.0.4",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp"
    ]
  },
  "private": true,
  "scripts": {
    "build": "make build-all-js",
    "check-deps": "node scripts/check-deps.js",
    "check:cards": "pnpm --filter @onsocial/text-card --filter @onsocial/sdk --filter onsocial-gateway run check",
    "clean": "pnpm -r run clean",
    "dev": "pnpm -r run dev",
    "format": "pnpm -r run format",
    "format-deps": "syncpack format",
    "lint": "make lint-all-js",
    "postinstall": "node scripts/sync-deps.js",
    "prepare": "husky",
    "start": "pnpm -r run start",
    "sync-deps": "node scripts/sync-deps.js",
    "test": "make test-all-js",
    "typecheck": "make check-all-js",
    "upgrade:deps": "make upgrade-deps-js"
  },
  "workspaces": [
    "packages/*"
  ],
  "packageManager": "pnpm@10.32.1",
  "dependencies": {
    "@near-js/accounts": "^2.5.1",
    "@near-js/keystores": "^2.5.1",
    "@near-js/keystores-node": "^2.5.1",
    "@near-js/providers": "^2.5.1",
    "@near-js/signers": "^2.5.1",
    "near-api-js": "^7.1.0"
  }
}
