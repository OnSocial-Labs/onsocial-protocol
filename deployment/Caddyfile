# OnSocial Production Caddyfile
# Auto-TLS via Let's Encrypt
#
# SINGLE PUBLIC ENTRY POINT — only the API gateway is exposed.
# Hasura, Relay, and Postgres are internal-only (Docker network).
# Admin access: SSH tunnel to the server for Hasura Console or Postgres.
#
#   ssh -L 8080:localhost:8080 your-server   # Hasura Console
#   ssh -L 5432:localhost:5432 your-server   # Postgres
#
# DNS records are injected by the deploy scripts.
# The generated Caddyfile should only contain the hostnames for the target
# environment so testnet and mainnet stay explicitly separated.

# ---------- API Gateway (sole public surface) ----------
__SERVER_NAMES__ {
	# 100 req/s per IP — protects infra before requests reach the app
	rate_limit {
		zone per_ip {
			key    {remote_host}
			events 100
			window 1s
		}
	}

	# Telegram webhook → backend (must be before catch-all)
	handle /webhooks/telegram {
		reverse_proxy __BACKEND_UPSTREAM__
	}

	# Partner Rewards SDK API → backend
	handle /v1/* {
		reverse_proxy __BACKEND_UPSTREAM__
	}

	# Everything else → gateway
	handle {
		reverse_proxy __GATEWAY_UPSTREAM__
	}

	header {
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
		Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"
		-Server
	}

	request_body {
		max_size 10MB
	}

	log {
		output file /data/logs/gateway.log {
			roll_size 50MB
			roll_keep 5
		}
	}
}

# ---------- Pages (*.onsocial.id profile pages) ----------
*.onsocial.id {
	tls {
		on_demand
	}

	rate_limit {
		zone pages_per_ip {
			key    {remote_host}
			events 60
			window 1s
		}
	}

	reverse_proxy pages:3456

	header {
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
		Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"
		-Server
	}

	log {
		output file /data/logs/pages.log {
			roll_size 50MB
			roll_keep 3
		}
	}
}
