# OnSocial Production Caddyfile
# Auto-TLS via Let's Encrypt
#
# SINGLE PUBLIC ENTRY POINT — only the API gateway is exposed.
# Hasura, Relay, and Postgres are internal-only (Docker network).
# Admin access: SSH tunnel to the server for Hasura Console or Postgres.
#
#   ssh -L 8080:localhost:8080 your-server   # Hasura Console
#   ssh -L 5432:localhost:5432 your-server   # Postgres
#
# DNS records are injected by the deploy scripts.
# The generated Caddyfile should only contain the hostnames for the target
# environment so testnet and mainnet stay explicitly separated.

# ---------- Global: on-demand TLS for *.onsocial.id ----------
# Pages issues per-subdomain certs as requests arrive.
# The "ask" endpoint validates the subdomain before issuing a cert.
{
	on_demand_tls {
		ask http://pages:3456/caddy-ask
	}
}

# ---------- API Gateway (sole public surface) ----------
# Caddy serves the most specific match first, so this block wins
# over the *.onsocial.id wildcard for testnet.onsocial.id / api.onsocial.id.
__SERVER_NAMES__ {
	# 100 req/s per IP — protects infra before requests reach the app
	rate_limit {
		zone per_ip {
			key    {remote_host}
			events 100
			window 1s
		}
	}

	# Telegram webhook → backend (must be before catch-all)
	handle /webhooks/telegram {
		reverse_proxy __BACKEND_UPSTREAM__
	}

	# Partner Rewards SDK API → backend
	handle /v1/* {
		reverse_proxy __BACKEND_UPSTREAM__
	}

	# Everything else → gateway
	handle {
		reverse_proxy __GATEWAY_UPSTREAM__
	}

	header {
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
		Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"
		-Server
	}

	request_body {
		max_size 10MB
	}

	log {
		output file /data/logs/gateway.log {
			roll_size 50MB
			roll_keep 5
		}
	}
}

# ---------- IPFS gateway proxy (cdn.{testnet.,}onsocial.id) ----------
# Brand-stable IPFS gateway under our own domain. Reverse-proxies to the
# Lighthouse per-account subdomain so users (and on-chain `media` URLs)
# never reference Lighthouse-owned hostnames directly. If we ever change
# storage providers, only the upstream below has to change — every NFT
# already minted keeps resolving.
#
# Caddy automatically caches responses at the OS-page-cache layer; for a
# proper HTTP cache (disk-backed, becomes a de-facto second pin) build the
# image with the cache-handler plugin (see docker/Dockerfile.caddy).
__CDN_DOMAIN__ {
	encode zstd gzip

	@ipfs path /ipfs/*
	handle @ipfs {
		# IPFS content is immutable — cache aggressively at every layer.
		header Cache-Control "public, max-age=31536000, immutable"
		header Access-Control-Allow-Origin "*"
		header Access-Control-Allow-Methods "GET, HEAD, OPTIONS"
		header -Server

		rate_limit {
			zone cdn_per_ip {
				key    {remote_host}
				events 60
				window 1s
			}
		}

		reverse_proxy https://__CDN_UPSTREAM__ {
			header_up Host __CDN_UPSTREAM__
			transport http {
				tls
				keepalive 60s
			}
		}
	}

	respond /health "ok" 200
	handle {
		respond 404
	}

	log {
		output file /data/logs/cdn.log {
			roll_size 50MB
			roll_keep 5
		}
	}
}

# ---------- Pages — profile subdomains ----------
# Use a catch-all HTTPS server with on-demand TLS so Caddy issues
# individual subdomain certs at handshake time instead of trying to
# automate a wildcard certificate at startup.
https:// {
	tls {
		on_demand
	}

	@pages host __PAGES_HOST_PATTERNS__
	handle @pages {
		rate_limit {
			zone pages_per_ip {
				key    {remote_host}
				events 30
				window 1s
			}
		}

		reverse_proxy pages:3456

		header {
			X-Content-Type-Options "nosniff"
			Referrer-Policy "strict-origin-when-cross-origin"
			Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"
			-Server
		}
	}

	handle {
		abort
	}

	log {
		output file /data/logs/pages.log {
			roll_size 50MB
			roll_keep 5
		}
	}
}
