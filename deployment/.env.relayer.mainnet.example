# Single-host mainnet relayer env example
# Copy to .env.relayer on the target host, or generate it during deploy.

IMAGE_TAG=mainnet-relayer-latest
RELAYER_INSTANCE_NAME=relayer-0
RELAYER_BIND_IP=0.0.0.0
RELAYER_PORT=3040

NEAR_NETWORK=mainnet
RELAYER_ACCOUNT_ID=relayer.onsocial.near
RELAYER_ALLOWED_CONTRACTS=rewards.onsocial.near

GCP_KMS_PROJECT=onsocial-protocol
GCP_KMS_LOCATION=global
GCP_KMS_ADMIN_KEY=admin-key
GCP_KMS_POOL_SIZE=30
GCP_KMS_KEYRING=relayer-keys-mainnet

RELAYER_MIN_KEYS=30
RELAYER_MAX_KEYS=200
RELAYER_WARM_BUFFER=2
RELAYER_MAX_KEY_AGE=86400

RELAYER_API_KEY=<pulled from GSM>
LAVA_API_KEY=<pulled from GSM>

# Optional explicit RPC overrides.
RELAYER_RPC_URL=
RELAYER_FALLBACK_RPC_URL=
